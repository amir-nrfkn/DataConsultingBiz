---
/**
 * Header.astro — Sticky site header with navigation and CTA.
 *
 * Features:
 * - SVG text wordmark for "Veylor Advisory"
 * - Nav links as anchor links to homepage sections
 * - Primary CTA button ("Book a Discovery Call")
 * - Mobile hamburger menu with accessible toggle
 * - Backdrop blur + subtle border on scroll (via small inline script)
 */
import { site } from '../data/site';
---

<header class="header" id="site-header">
  <div class="header__inner container">
    <!-- Wordmark / logo -->
    <a href="/" class="header__logo" aria-label={`${site.name} — Home`}>
      <svg
        class="header__wordmark"
        viewBox="0 0 220 28"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-label={site.name}
      >
        <text
          x="0"
          y="22"
          font-family="ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
          font-size="20"
          font-weight="700"
          fill="currentColor"
          letter-spacing="-0.02em"
        >
          Veylor
          <tspan font-weight="400" dx="2">Advisory</tspan>
        </text>
      </svg>
    </a>

    <!-- Desktop navigation -->
    <nav class="header__nav" aria-label="Main navigation">
      <ul class="header__nav-list" role="list">
        <li><a href="#process" class="header__nav-link">How It Works</a></li>
        <li><a href="#examples" class="header__nav-link">Examples</a></li>
        <li><a href="#faq" class="header__nav-link">FAQ</a></li>
        <li><a href="#contact" class="header__nav-link">Contact</a></li>
      </ul>
    </nav>

    <!-- CTA + mobile toggle -->
    <div class="header__actions">
      <a href="#contact" class="btn btn-primary header__cta">Book a Discovery Call</a>

      <!-- Mobile hamburger button -->
      <button
        class="header__hamburger"
        id="mobile-menu-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open navigation menu"
      >
        <span class="header__hamburger-line"></span>
        <span class="header__hamburger-line"></span>
        <span class="header__hamburger-line"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="header__mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      <ul class="header__mobile-list" role="list">
        <li><a href="#process" class="header__mobile-link">How It Works</a></li>
        <li><a href="#examples" class="header__mobile-link">Examples</a></li>
        <li><a href="#faq" class="header__mobile-link">FAQ</a></li>
        <li><a href="#contact" class="header__mobile-link">Contact</a></li>
      </ul>
      <a href="#contact" class="btn btn-primary header__mobile-cta">Book a Discovery Call</a>
    </nav>
  </div>
</header>

<!-- Minimal inline script for scroll detection + mobile menu toggle. -->
<script>
  const header = document.getElementById('site-header');
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  /* Add "scrolled" class to header after 10px of scroll for visual treatment. */
  if (header) {
    window.addEventListener('scroll', () => {
      header.classList.toggle('header--scrolled', window.scrollY > 10);
    }, { passive: true });
  }

  /* Toggle mobile menu open/close. */
  if (toggleBtn && mobileMenu) {
    toggleBtn.addEventListener('click', () => {
      const isOpen = toggleBtn.getAttribute('aria-expanded') === 'true';
      toggleBtn.setAttribute('aria-expanded', String(!isOpen));
      mobileMenu.setAttribute('aria-hidden', String(isOpen));
      mobileMenu.classList.toggle('header__mobile-menu--open', !isOpen);
      toggleBtn.classList.toggle('header__hamburger--active', !isOpen);
    });

    /* Close mobile menu when a link inside it is clicked. */
    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        toggleBtn.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
        mobileMenu.classList.remove('header__mobile-menu--open');
        toggleBtn.classList.remove('header__hamburger--active');
      });
    });
  }
</script>

<style>
  /* ─── Sticky header ─── */
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: rgba(250, 250, 250, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition-base),
                background-color var(--transition-base);
  }

  .header--scrolled {
    border-bottom-color: var(--color-border);
    background-color: rgba(250, 250, 250, 0.95);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  /* ─── Wordmark ─── */
  .header__logo {
    display: flex;
    align-items: center;
    color: var(--color-text);
    text-decoration: none;
  }

  .header__logo:hover {
    color: var(--color-text);
  }

  .header__wordmark {
    height: 24px;
    width: auto;
  }

  /* ─── Desktop nav ─── */
  .header__nav {
    display: none;
  }

  .header__nav-list {
    display: flex;
    gap: var(--space-8);
  }

  .header__nav-link {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    text-decoration: none;
    padding: var(--space-2) 0;
    transition: color var(--transition-fast);
  }

  .header__nav-link:hover {
    color: var(--color-text);
  }

  /* ─── Actions ─── */
  .header__actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .header__cta {
    display: none;
  }

  /* ─── Hamburger button ─── */
  .header__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px;
    height: 32px;
    padding: 4px;
    cursor: pointer;
    background: none;
    border: none;
  }

  .header__hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-text);
    border-radius: 1px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  /* Animated X when open */
  .header__hamburger--active .header__hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .header__hamburger--active .header__hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .header__hamburger--active .header__hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ─── Mobile menu ─── */
  .header__mobile-menu {
    display: none;
    padding: var(--space-6) var(--container-padding) var(--space-8);
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .header__mobile-menu--open {
    display: block;
  }

  .header__mobile-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-6);
  }

  .header__mobile-link {
    display: block;
    padding: var(--space-3) var(--space-4);
    font-size: var(--text-lg);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: background-color var(--transition-fast);
  }

  .header__mobile-link:hover {
    background-color: var(--color-surface-alt);
    color: var(--color-text);
  }

  .header__mobile-cta {
    width: 100%;
    text-align: center;
  }

  /* ─── Desktop breakpoint (768px+) ─── */
  @media (min-width: 768px) {
    .header__nav {
      display: block;
    }

    .header__cta {
      display: inline-flex;
    }

    .header__hamburger {
      display: none;
    }

    .header__mobile-menu {
      display: none !important;
    }
  }
</style>
