---
import { proofIntro } from '../data/offer';
---

<section class="capability section" id="approach" aria-labelledby="approach-heading">
  <div class="container">
    <div class="capability__shell section-shell">
      <div class="capability__intro">
        <span class="eyebrow">{proofIntro.eyebrow}</span>
        <h2 class="section-heading" id="approach-heading">{proofIntro.title}</h2>
        <p class="section-subheading">{proofIntro.description}</p>
      </div>

      <div class="capability__comparison">
        <div class="capability__column">
          <span class="capability__column-label">{proofIntro.comparison.beforeTitle}</span>
          <ul class="capability__list" role="list">
            {proofIntro.comparison.beforeItems.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>

        <div class="capability__divider" aria-hidden="true"></div>

        <div class="capability__column capability__column--after">
          <span class="capability__column-label">{proofIntro.comparison.afterTitle}</span>
          <ul class="capability__list" role="list">
            {proofIntro.comparison.afterItems.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .capability__shell {
    padding: clamp(2rem, 4vw, 3rem);
  }

  .capability__intro {
    max-width: 720px;
    margin-bottom: clamp(2rem, 5vw, 3.75rem);
  }

  .capability__intro .eyebrow {
    margin-bottom: var(--space-4);
  }

  .capability__comparison {
    display: grid;
    gap: var(--space-6);
    padding: clamp(1.5rem, 3vw, 2.25rem);
    border-radius: calc(var(--radius-xl) - 8px);
    background: linear-gradient(180deg, rgba(245, 245, 247, 0.95) 0%, rgba(255, 255, 255, 0.92) 100%);
    border: 1px solid rgba(29, 29, 31, 0.06);
  }

  .capability__column-label {
    display: inline-flex;
    margin-bottom: var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .capability__list {
    display: grid;
    gap: var(--space-4);
  }

  .capability__list li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--color-text-muted);
    line-height: 1.55;
  }

  .capability__list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.58rem;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: rgba(29, 29, 31, 0.18);
  }

  .capability__column--after .capability__list li {
    color: var(--color-text);
  }

  .capability__column--after .capability__list li::before {
    background: var(--color-accent);
  }

  .capability__divider {
    display: none;
  }

  @media (min-width: 760px) {
    .capability__outcomes {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .capability__comparison {
      grid-template-columns: 1fr auto 1fr;
      align-items: start;
    }

    .capability__divider {
      display: block;
      width: 1px;
      align-self: stretch;
      background: linear-gradient(180deg, transparent 0%, rgba(29, 29, 31, 0.12) 20%, rgba(29, 29, 31, 0.12) 80%, transparent 100%);
    }
  }
</style>
