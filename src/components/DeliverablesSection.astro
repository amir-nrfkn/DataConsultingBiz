---
import { deliverables, outOfScope, pricing } from '../data/offer';
---

<section class="deliverables section" id="deliverables" aria-labelledby="deliverables-heading">
  <div class="deliverables__inner container">
    <div class="deliverables__header">
      <span class="eyebrow">Scope and pricing</span>
      <h2 class="section-heading" id="deliverables-heading">A focused engagement with a clear finish line</h2>
      <p class="section-subheading">
        This is designed to create a durable operating layer, not an open-ended
        consulting loop. The scope stays tight enough to move quickly.
      </p>
    </div>

    <div class="deliverables__layout section-shell">
      <div class="deliverables__scope-grid">
        <div class="deliverables__scope">
          <span class="deliverables__label">Included in the sprint</span>
          <ul class="deliverables__list" role="list">
            {deliverables.map((item) => (
              <li class="deliverables__item">
                <span class="deliverables__check" aria-hidden="true"></span>
                <span class="deliverables__text">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <div class="deliverables__exclusions">
          <span class="deliverables__label">Typically out of scope</span>
          <ul class="deliverables__exclusions-list" role="list">
            {outOfScope.map((item) => (
              <li>
                <span class="deliverables__x" aria-hidden="true">✕</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div class="deliverables__pricing">
        <div class="deliverables__price-card">
          <span class="deliverables__price-label">{pricing.setupLabel}</span>
          <span class="deliverables__price-value">{pricing.setup}</span>
          <p>Designed to get the foundation in place without turning into a long implementation program.</p>
        </div>

        <div class="deliverables__price-card deliverables__price-card--secondary">
          <span class="deliverables__price-label">{pricing.supportLabel}</span>
          <span class="deliverables__price-value">{pricing.ongoing}</span>
          <p>{pricing.ongoingNote}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .deliverables__header {
    max-width: 1080px;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
    
  }

  .deliverables__header .eyebrow {
    margin-bottom: var(--space-4);
  }

  .deliverables__layout {
    display: grid;
    gap: clamp(1.75rem, 4vw, 2.8rem);
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }

  .deliverables__scope-grid {
    display: grid;
    gap: clamp(1.5rem, 3vw, 2.25rem);
    align-items: start;
    padding-bottom: clamp(1.5rem, 3vw, 2rem);
    border-bottom: 1px solid rgba(29, 29, 31, 0.08);
  }

  .deliverables__scope,
  .deliverables__exclusions {
    min-width: 0;
  }

  .deliverables__label {
    display: inline-flex;
    margin-bottom: var(--space-5);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #4b4b51;
  }

  .deliverables__list,
  .deliverables__exclusions-list {
    display: grid;
    gap: var(--space-4);
  }

  .deliverables__item,
  .deliverables__exclusions-list li {
    display: flex;
    gap: var(--space-3);
    color: var(--color-text-muted);
    line-height: 1.55;
  }

  .deliverables__check {
    width: 0.65rem;
    height: 0.65rem;
    margin-top: 0.5rem;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .deliverables__x {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 0.85rem;
    margin-top: 0.15rem;
    color: var(--color-text-soft);
    font-size: 0.82rem;
    font-weight: var(--weight-semibold);
    line-height: 1;
    flex-shrink: 0;
  }

  .deliverables__pricing {
    display: grid;
    gap: clamp(1rem, 2.5vw, 1.5rem);
    align-items: stretch;
  }

  .deliverables__price-card {
    display: grid;
    gap: var(--space-3);
    min-height: 100%;
    padding: clamp(1.4rem, 3vw, 1.8rem);
    border-radius: calc(var(--radius-xl) - 10px);
    background: rgba(245, 245, 247, 0.9);
    border: 1px solid rgba(29, 29, 31, 0.06);
  }

  .deliverables__price-label {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: var(--weight-semibold);
  }

  .deliverables__price-value {
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    font-weight: var(--weight-semibold);
    letter-spacing: -0.04em;
    color: var(--color-text);
  }

  .deliverables__price-card p {
    color: var(--color-text-muted);
    max-width: 26ch;
  }

  .deliverables__price-card--secondary {
    background: rgba(255, 255, 255, 0.72);
  }

  @media (min-width: 768px) {
    .deliverables__scope-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .deliverables__pricing {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .deliverables__price-card {
      min-height: 15rem;
    }
  }

  @media (min-width: 1024px) {
    .deliverables__layout {
      gap: clamp(2rem, 4vw, 3rem);
      padding: clamp(2rem, 4vw, 2.75rem);
    }

    .deliverables__scope-grid {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      column-gap: clamp(2rem, 4vw, 3rem);
    }

    .deliverables__pricing {
      column-gap: clamp(1.5rem, 3vw, 2rem);
    }

    .deliverables__price-card {
      min-height: 16rem;
    }
  }
</style>
