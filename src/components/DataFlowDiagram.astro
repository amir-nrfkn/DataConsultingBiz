---
/**
 * DataFlowDiagram.astro — Pure SVG data flow diagram.
 * Desktop and mobile versions with responsive visibility.
 * Converted from a React/Tailwind component to Astro.
 */
---

<div class="dataflow">
  <!-- DESKTOP VERSION — shown on md+ -->
  <div class="dataflow__desktop">
    <svg
      viewBox="0 0 1000 490"
      class="dataflow__svg"
      role="img"
      font-family="-apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif"
      aria-label="Diagram showing Spreadsheets, ERP, CRM, and Finance feeding into a Trusted Layer, which powers an AI Analyst."
    >
      <title>Trusted data layer diagram</title>
      <desc>
        Spreadsheets, ERP, CRM, and Finance connect into a trusted layer,
        which then powers an AI Analyst in Slack, Teams, or WhatsApp.
      </desc>

      <defs>
        <filter id="df-shadow" x="-50%" y="-50%" width="200%" height="200%">
          <feDropShadow dx="0" dy="3" stdDeviation="10" flood-color="#06182c" flood-opacity="0.08" />
        </filter>
      </defs>

      <!-- Source pills (accent-tinted background, accent text) -->
      <g filter="url(#df-shadow)">
        <rect x="30"  y="100" width="210" height="72" rx="36" fill="#e8f3ff" />
        <rect x="275" y="20"  width="210" height="72" rx="36" fill="#e8f3ff" />
        <rect x="515" y="20"  width="210" height="72" rx="36" fill="#e8f3ff" />
        <rect x="760" y="100" width="210" height="72" rx="36" fill="#e8f3ff" />
      </g>

      <text x="135" y="142" text-anchor="middle" font-size="18" font-weight="600" fill="#0071e3">Spreadsheets</text>
      <text x="380" y="62"  text-anchor="middle" font-size="18" font-weight="600" fill="#0071e3">ERP</text>
      <text x="620" y="62"  text-anchor="middle" font-size="18" font-weight="600" fill="#0071e3">CRM</text>
      <text x="865" y="142" text-anchor="middle" font-size="18" font-weight="600" fill="#0071e3">Finance</text>

      <!-- Connector lines — muted gray, tree topology, no crossings -->
      <g stroke="#c7c7cc" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path d="M135 172 V215 H500 V245" />
        <path d="M380 92  V215 H500 V245" />
        <path d="M620 92  V215 H500 V245" />
        <path d="M865 172 V215 H500 V245" />
        <path d="M500 297 V355" />
      </g>

      <!-- Trusted Layer (accent blue — the hero of the diagram) -->
      <g filter="url(#df-shadow)">
        <rect x="120" y="245" width="760" height="52" rx="12" fill="#0071e3" />
      </g>
      <text x="500" y="278" text-anchor="middle" font-size="20" font-weight="600" fill="#ffffff" letter-spacing="-0.01em">Trusted Layer</text>

      <!-- AI Analyst card -->
      <g filter="url(#df-shadow)">
        <rect x="200" y="355" width="600" height="84" rx="42" fill="#ffffff" stroke="rgba(29,29,31,0.08)" stroke-width="1" />
      </g>

      <!-- Accent sparkles -->
      <g fill="#0071e3">
        <polygon points="255,381 261,393 275,397 261,401 255,413 249,401 235,397 249,393" />
        <polygon points="290,403 293,411 301,414 293,417 290,425 287,417 279,414 287,411" />
      </g>

      <!-- AI Analyst text -->
      <text x="320" y="393" font-size="22" font-weight="600" fill="#1d1d1f" letter-spacing="-0.01em">AI Analyst</text>
      <text x="320" y="419" font-size="14" fill="#6e6e73">Answers in Slack, Teams, or WhatsApp</text>
    </svg>
  </div>

  <!-- MOBILE VERSION — shown below md -->
  <div class="dataflow__mobile">
    <svg
      viewBox="0 0 420 470"
      class="dataflow__svg"
      role="img"
      font-family="-apple-system, BlinkMacSystemFont, 'SF Pro Display', 'SF Pro Text', 'Helvetica Neue', Helvetica, Arial, sans-serif"
      aria-label="Mobile diagram showing systems feeding into a Trusted Layer and then into an AI Analyst."
    >
      <defs>
        <filter id="df-shadow-m" x="-50%" y="-50%" width="200%" height="200%">
          <feDropShadow dx="0" dy="3" stdDeviation="10" flood-color="#06182c" flood-opacity="0.08" />
        </filter>
      </defs>

      <!-- Source pills (2x2 grid) -->
      <g filter="url(#df-shadow-m)">
        <rect x="20"  y="30"  width="170" height="60" rx="30" fill="#e8f3ff" />
        <rect x="230" y="30"  width="170" height="60" rx="30" fill="#e8f3ff" />
        <rect x="20"  y="110" width="170" height="60" rx="30" fill="#e8f3ff" />
        <rect x="230" y="110" width="170" height="60" rx="30" fill="#e8f3ff" />
      </g>

      <text x="105" y="66"  text-anchor="middle" font-size="16" font-weight="600" fill="#0071e3">Spreadsheets</text>
      <text x="315" y="66"  text-anchor="middle" font-size="16" font-weight="600" fill="#0071e3">ERP</text>
      <text x="105" y="146" text-anchor="middle" font-size="16" font-weight="600" fill="#0071e3">CRM</text>
      <text x="315" y="146" text-anchor="middle" font-size="16" font-weight="600" fill="#0071e3">Finance</text>

      <!-- Connector lines — each source exits sideways into the central trunk,
           avoiding the stacked pills in the column beneath. -->
      <g stroke="#c7c7cc" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path d="M190 60  H210 V240" />
        <path d="M230 60  H210 V240" />
        <path d="M190 140 H210 V240" />
        <path d="M230 140 H210 V240" />
        <path d="M210 288 V340" />
      </g>

      <!-- Trusted Layer -->
      <g filter="url(#df-shadow-m)">
        <rect x="20" y="240" width="380" height="48" rx="12" fill="#0071e3" />
      </g>
      <text x="210" y="270" text-anchor="middle" font-size="18" font-weight="600" fill="#ffffff" letter-spacing="-0.01em">Trusted Layer</text>

      <!-- AI Analyst card -->
      <g filter="url(#df-shadow-m)">
        <rect x="30" y="340" width="360" height="84" rx="42" fill="#ffffff" stroke="rgba(29,29,31,0.08)" stroke-width="1" />
      </g>

      <!-- Accent sparkles -->
      <g fill="#0071e3">
        <polygon points="65,366 71,378 85,382 71,386 65,398 59,386 45,382 59,378" />
        <polygon points="100,388 103,396 111,399 103,402 100,410 97,402 89,399 97,396" />
      </g>

      <!-- AI Analyst text -->
      <text x="130" y="378" font-size="18" font-weight="600" fill="#1d1d1f" letter-spacing="-0.01em">AI Analyst</text>
      <text x="130" y="402" font-size="13" fill="#6e6e73">Answers in Slack, Teams, or WhatsApp</text>
    </svg>
  </div>
</div>

<style>
  .dataflow {
    width: 100%;
  }

  .dataflow__svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .dataflow__desktop {
    display: none;
  }

  .dataflow__mobile {
    display: block;
  }

  @media (min-width: 768px) {
    .dataflow__desktop {
      display: block;
    }

    .dataflow__mobile {
      display: none;
    }
  }
</style>
