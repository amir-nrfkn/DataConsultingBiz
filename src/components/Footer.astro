---
import { site } from '../data/site';

const currentYear = new Date().getFullYear();
const isExternalBooking = site.bookingUrl.startsWith('http');
---

<footer class="footer" role="contentinfo">
  <div class="footer__inner container">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label={`${site.name} — Home`}>
          <svg
            class="footer__wordmark"
            viewBox="0 0 220 28"
            xmlns="http://www.w3.org/2000/svg"
            role="img"
            aria-label={site.name}
          >
            <text
              x="0"
              y="22"
              font-family="ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif"
              font-size="20"
              font-weight="700"
              fill="currentColor"
              letter-spacing="-0.02em"
            >
              Veylor
              <tspan font-weight="400" dx="2">Advisory</tspan>
            </text>
          </svg>
        </a>
        <p class="footer__tagline">{site.tagline}</p>
      </div>

      <div class="footer__nav-col">
        <h3 class="footer__col-label">Explore</h3>
        <nav aria-label="Footer navigation">
          <ul class="footer__nav-list" role="list">
            <li><a href="#approach" class="footer__link">Approach</a></li>
            <li><a href="#process" class="footer__link">How It Works</a></li>
            <li><a href="#examples" class="footer__link">Outcomes</a></li>
            <li><a href="#deliverables" class="footer__link">Scope & Pricing</a></li>
            <li><a href="#faq" class="footer__link">FAQ</a></li>
          </ul>
        </nav>
      </div>

      <div class="footer__contact-col">
        <h3 class="footer__col-label">Start</h3>
        <ul class="footer__nav-list" role="list">
          <li>
            <a
              href={site.bookingUrl}
              class="footer__link"
              target={isExternalBooking ? '_blank' : undefined}
              rel={isExternalBooking ? 'noreferrer' : undefined}
            >
              {site.bookingLabel}
            </a>
          </li>
          <li><a href="#contact" class="footer__link">Send your details</a></li>
          <li><a href={`mailto:${site.email}`} class="footer__link">{site.email}</a></li>
          <li>
            <a href={site.linkedin} class="footer__link" target="_blank" rel="noopener noreferrer">
              LinkedIn ↗
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copyright">© {currentYear} {site.name}. All rights reserved.</p>
      <a href="/privacy" class="footer__link footer__privacy-link">Privacy Policy</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: transparent;
    color: var(--color-text);
    padding-top: var(--space-16);
    padding-bottom: var(--space-8);
    border-top: 1px solid rgba(29, 29, 31, 0.08);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    padding-bottom: var(--space-10);
    border-bottom: 1px solid rgba(29, 29, 31, 0.08);
    margin-bottom: var(--space-8);
  }

  .footer__logo {
    display: inline-flex;
    color: var(--color-text);
    text-decoration: none;
    margin-bottom: var(--space-4);
  }

  .footer__logo:hover {
    color: var(--color-text);
  }

  .footer__wordmark {
    height: 24px;
    width: auto;
  }

  .footer__tagline {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.58;
    max-width: 40ch;
  }

  .footer__col-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-soft);
    margin-bottom: var(--space-4);
  }

  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__link:hover {
    color: var(--color-text);
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__copyright,
  .footer__privacy-link {
    font-size: var(--text-xs);
    color: var(--color-text-soft);
  }

  @media (min-width: 768px) {
    .footer__top {
      grid-template-columns: 2fr 1fr 1fr;
    }

    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
