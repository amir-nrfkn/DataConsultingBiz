---
/**
 * SeoHead.astro — Reusable <head> partial for all pages.
 *
 * Renders title, meta description, canonical URL, Open Graph tags,
 * Twitter card tags, favicon links, theme-color, and JSON-LD
 * structured data. Every page passes SeoProps via the layout.
 */
import type { SeoProps } from '../utils/seo';
import { site } from '../data/site';

interface Props {
  seo: SeoProps;
  /** Optional: JSON-LD schema objects to inject into the head. */
  schemas?: Record<string, unknown>[];
}

const { seo, schemas = [] } = Astro.props;

/* Build the full canonical URL from the site base + the page path. */
const canonicalUrl = new URL(seo.canonicalPath, site.url).toString();

/* OG image — falls back to a placeholder path. */
const ogImageUrl = seo.ogImage
  ? new URL(seo.ogImage, site.url).toString()
  : undefined;
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- Title & description -->
  <title>{seo.title}</title>
  <meta name="description" content={seo.description} />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalUrl} />

  {/* No-index for pages like thank-you and 404 */}
  {seo.noIndex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={seo.title} />
  <meta property="og:description" content={seo.description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={site.name} />
  {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={seo.title} />
  <meta name="twitter:description" content={seo.description} />
  {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

  <!-- Theme color (accent) -->
  <meta name="theme-color" content="#0071E3" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico" />
  <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png" />

  <!-- JSON-LD Structured Data -->
  {schemas.map((schema) => (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(schema)}
    />
  ))}
</head>
