---
import { site } from '../data/site';

const isExternalBooking = site.bookingUrl.startsWith('http');
---

<section class="contact section section--alt" id="contact" aria-labelledby="contact-heading">
  <div class="contact__inner container">
    <div class="contact__header">
      <span class="eyebrow">Prefer to share context first?</span>
      <h2 class="section-heading" id="contact-heading">Send your details</h2>
      <p class="section-subheading">
        We’ll review your setup and reply personally. Or <a href={site.bookingUrl} target="_blank" rel="noreferrer">book a call</a> if you’re ready to talk.
      </p>
      <a
        href={site.bookingUrl}
        class="btn btn-primary contact__booking-btn"
        target={isExternalBooking ? '_blank' : undefined}
        rel={isExternalBooking ? 'noreferrer' : undefined}
      >
        {site.bookingLabel}
      </a>
    </div>

    <form
      class="contact__form section-shell"
      name="lead-capture"
      method="POST"
      action="/thank-you"
      data-netlify="true"
      netlify-honeypot="bot-field"
      id="lead-capture-form"
    >
      <p class="sr-only" aria-hidden="true">
        <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
      </p>

      <input type="hidden" name="form-name" value="lead-capture" />

      <div class="contact__fields">
        <div class="contact__field">
          <label for="contact-name" class="contact__label">
            Name <span class="contact__required" aria-hidden="true">*</span>
          </label>
          <input
            type="text"
            name="name"
            id="contact-name"
            required
            autocomplete="name"
            placeholder="Your full name"
            class="contact__input"
          />
        </div>

        <div class="contact__field">
          <label for="contact-email" class="contact__label">
            Work email <span class="contact__required" aria-hidden="true">*</span>
          </label>
          <input
            type="email"
            name="email"
            id="contact-email"
            required
            autocomplete="email"
            placeholder="you@company.com"
            class="contact__input"
          />
        </div>

        <div class="contact__field">
          <label for="contact-company" class="contact__label">
            Company name <span class="contact__required" aria-hidden="true">*</span>
          </label>
          <input
            type="text"
            name="company"
            id="contact-company"
            required
            autocomplete="organization"
            placeholder="Your company"
            class="contact__input"
          />
        </div>

        <div class="contact__field contact__field--wide">
          <label for="contact-issue" class="contact__label">
            Biggest reporting or data issue <span class="contact__required" aria-hidden="true">*</span>
          </label>
          <textarea
            name="issue"
            id="contact-issue"
            required
            rows="3"
            placeholder="What is the most painful data or reporting problem your team faces today?"
            class="contact__input contact__textarea"
          ></textarea>
        </div>
      </div>

      <div class="contact__submit-row">
        <button type="submit" class="btn btn-primary contact__submit" id="contact-submit-btn">
          Submit Inquiry
        </button>
        <p class="contact__trust-note">
          We'll review your setup and reply personally. No automated sales sequence.
        </p>
      </div>
    </form>
  </div>
</section>

<style>
  .contact__header {
    max-width: 760px;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
    margin-inline: auto;
    text-align: center;
  }

  .contact__header .eyebrow {
    margin-bottom: var(--space-4);
  }

  .contact__booking-btn {
    margin-top: var(--space-4);
  }

  .contact__form {
    max-width: 820px;
    width: 100%;
    margin-inline: auto;
    text-align: left;
    padding: clamp(1.5rem, 4vw, 2.4rem);
  }

  .contact__fields {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    margin-bottom: var(--space-8);
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact__label {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  .contact__required {
    color: #c0392b;
  }

  .contact__optional {
    font-weight: var(--weight-normal);
    color: var(--color-text-muted);
  }

  .contact__input {
    width: 100%;
    padding: var(--space-3) var(--space-4);
    border: 1px solid rgba(29, 29, 31, 0.1);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.78);
    font-size: var(--text-base);
    color: var(--color-text);
    transition: border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      background-color var(--transition-fast);
  }

  .contact__input::placeholder {
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .contact__input:focus {
    border-color: rgba(0, 113, 227, 0.35);
    background: #fff;
    box-shadow: 0 0 0 4px rgba(0, 113, 227, 0.08);
    outline: none;
  }

  .contact__textarea {
    min-height: 7.5rem;
    resize: vertical;
  }

  .contact__select {
    appearance: none;
    background-image:
      linear-gradient(45deg, transparent 50%, var(--color-text-muted) 50%),
      linear-gradient(135deg, var(--color-text-muted) 50%, transparent 50%);
    background-position:
      calc(100% - 20px) calc(50% - 3px),
      calc(100% - 14px) calc(50% - 3px);
    background-size: 6px 6px;
    background-repeat: no-repeat;
  }

  .contact__submit-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    align-items: flex-start;
  }

  .contact__trust-note {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    line-height: var(--leading-normal);
  }

  @media (min-width: 720px) {
    .contact__fields {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .contact__field--wide {
      grid-column: 1 / -1;
    }
  }
</style>
