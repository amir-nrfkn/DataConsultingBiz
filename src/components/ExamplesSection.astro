---
import { examples } from '../data/examples';
---

<section class="examples section" id="examples" aria-labelledby="examples-heading">
  <div class="examples__inner container">
    <div class="examples__header">
      <span class="eyebrow">Illustrative outcomes</span>
      <h2 class="section-heading" id="examples-heading">What this can look like in practice</h2>
      <p class="section-subheading">
        Based on common engagements with growing operational businesses. These
        are anonymized examples, written to show how the work translates into
        clearer decisions and faster reporting.
      </p>
    </div>

    <div class="examples__list">
      {examples.map((example) => (
        <article class="examples__card section-shell">
          <div class="examples__summary">
            <div>
              <div class="examples__badges">
                {example.badges.map((badge) => (
                  <span class="examples__badge">{badge}</span>
                ))}
              </div>

              <h3 class="examples__title">{example.title}</h3>
              <p class="examples__profile">{example.profile}</p>
            </div>

            <p class="examples__highlight">{example.highlight}</p>
          </div>

          <div class="examples__sections">
            <section class="examples__block">
              <h4 class="examples__block-label">Core pain</h4>
              <p class="examples__block-text">{example.problem}</p>
            </section>

            <section class="examples__block">
              <h4 class="examples__block-label">What we changed</h4>
              <p class="examples__block-text">{example.implementation}</p>
            </section>

            <section class="examples__block">
              <h4 class="examples__block-label">Business outcome</h4>
              <p class="examples__block-text">{example.outcome}</p>
            </section>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .examples__header {
    max-width: 1080px;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }

  .examples__header .eyebrow {
    margin-bottom: var(--space-4);
  }

  .examples__list {
    display: grid;
    gap: clamp(1.25rem, 4vw, 2rem);
  }

  .examples__card {
    padding: clamp(1.4rem, 4vw, 2.25rem);
  }

  .examples__summary {
    display: grid;
    gap: var(--space-5);
    margin-bottom: clamp(1.6rem, 4vw, 2.5rem);
  }

  .examples__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .examples__badge {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-soft);
  }

  .examples__title {
    font-size: clamp(1.8rem, 3vw, 2.65rem);
    letter-spacing: -0.04em;
    margin-bottom: var(--space-4);
    max-width: 18ch;
  }

  .examples__profile {
    color: var(--color-text-muted);
    max-width: 44rem;
  }

  .examples__highlight {
    align-self: end;
    max-width: 24ch;
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    line-height: 1.35;
    letter-spacing: -0.03em;
    color: var(--color-text);
  }

  .examples__sections {
    display: grid;
    gap: var(--space-6);
    padding-top: var(--space-6);
    border-top: 1px solid rgba(29, 29, 31, 0.08);
  }

  .examples__block-label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-accent);
    margin-bottom: var(--space-3);
    letter-spacing: 0.01em;
  }

  .examples__block-text {
    color: var(--color-text-muted);
    line-height: 1.58;
  }

  @media (min-width: 900px) {
    .examples__summary {
      grid-template-columns: minmax(0, 1.35fr) minmax(15rem, 20rem);
      align-items: end;
    }

    .examples__sections {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }
</style>
