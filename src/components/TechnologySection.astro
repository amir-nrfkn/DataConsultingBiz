---
/**
 * TechnologySection.astro — "Modern implementation, outcome-first delivery."
 *
 * Two-column layout: left side lists implementation capabilities,
 * right side shows 3 outcome cards. Focuses on what clients GET,
 * not on specific tooling. Replaces what was originally the "Bruin section."
 */
import { technologyCapabilities, technologyOutcomes } from '../data/offer';
---

<section class="tech section section--alt" id="technology" aria-labelledby="tech-heading">
  <div class="tech__inner container">
    <div class="tech__header">
      <h2 class="section-heading" id="tech-heading">
        Modern implementation, outcome-first delivery
      </h2>
      <p class="section-subheading">
        We use proven, production-grade data tools to build your foundation —
        but what matters is what you get at the end.
      </p>
    </div>

    <div class="tech__grid">
      <!-- Left: how we implement -->
      <div class="tech__capabilities">
        <h3 class="tech__column-label">How we implement</h3>
        <ul class="tech__cap-list" role="list">
          {technologyCapabilities.map((cap) => (
            <li class="tech__cap-item">
              <span class="tech__cap-bullet" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M2 7h10M7 2v10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </span>
              <span>{cap}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Right: what clients get -->
      <div class="tech__outcomes">
        <h3 class="tech__column-label">What you get</h3>
        <div class="tech__outcome-cards">
          {technologyOutcomes.map((outcome) => (
            <div class="tech__outcome-card">
              <h4 class="tech__outcome-title">{outcome.title}</h4>
              <p class="tech__outcome-desc">{outcome.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tech__header {
    margin-bottom: var(--space-12);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .tech__grid {
    display: grid;
    gap: var(--space-12);
  }

  .tech__column-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-6);
  }

  /* ─── Left column: capabilities ─── */
  .tech__cap-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .tech__cap-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .tech__cap-bullet {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: var(--radius-full);
    background: var(--color-accent-light);
    color: var(--color-accent);
  }

  /* ─── Right column: outcome cards ─── */
  .tech__outcome-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .tech__outcome-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    box-shadow: var(--shadow-sm);
  }

  .tech__outcome-title {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-2);
  }

  .tech__outcome-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  @media (min-width: 768px) {
    .tech__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-16);
      align-items: start;
    }
  }
</style>
