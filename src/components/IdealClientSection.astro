---
/**
 * IdealClientSection.astro — "Best fit for companies that have
 * outgrown spreadsheets but not yet built a real data layer."
 *
 * Checklist-style list of 7 fit criteria with checkmark icons.
 * Helps prospects self-qualify before reaching the contact form.
 */
import { fitCriteria } from '../data/offer';
---

<section class="fit section" id="fit" aria-labelledby="fit-heading">
  <div class="fit__inner container">
    <div class="fit__header">
      <h2 class="section-heading" id="fit-heading">
        Best fit for companies that have outgrown spreadsheets but not yet
        built a real data layer
      </h2>
      <p class="section-subheading">
        This engagement works best when your company matches most of these criteria.
      </p>
    </div>

    <div class="fit__content">
      <div class="fit__label">Is this you?</div>
      <ul class="fit__list" role="list">
        {fitCriteria.map((item) => (
          <li class="fit__item">
            <span class="fit__check" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                <rect x="1" y="1" width="20" height="20" rx="6" stroke="currentColor" stroke-width="1.5"/>
                <path d="M7 11.5l2.5 2.5 5.5-5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <span class="fit__text">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .fit__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .fit__header {
    margin-bottom: var(--space-10);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .fit__content {
    max-width: 600px;
  }

  .fit__label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-6);
  }

  .fit__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .fit__item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .fit__check {
    flex-shrink: 0;
    color: var(--color-accent);
    display: flex;
  }

  .fit__text {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    font-weight: var(--weight-medium);
  }
</style>
