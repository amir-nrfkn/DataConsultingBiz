---
/**
 * ProcessSection.astro — "How the AI Data Foundation Sprint works."
 *
 * 5-step horizontal process flow on desktop with a connecting line
 * between steps. Stacks vertically on mobile with a vertical line.
 * Each step has a numbered badge, title, and description.
 */
import { processSteps, offerName } from '../data/offer';
---

<section class="process section" id="process" aria-labelledby="process-heading">
  <div class="process__inner container">
    <div class="process__header">
      <h2 class="section-heading" id="process-heading">
        How the {offerName} works
      </h2>
      <p class="section-subheading">
        A structured engagement that takes you from messy, scattered data to a
        trusted foundation with an AI analyst — in weeks, not months.
      </p>
    </div>

    <div class="process__steps">
      {processSteps.map((item, index) => (
        <div class="process__step">
          <div class="process__step-badge" aria-hidden="true">
            {item.step}
          </div>
          {/* Connecting line between steps (not after the last step) */}
          {index < processSteps.length - 1 && (
            <div class="process__connector" aria-hidden="true"></div>
          )}
          <h3 class="process__step-title">{item.title}</h3>
          <p class="process__step-desc">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Text reveal scroll animation using IntersectionObserver
  document.addEventListener('DOMContentLoaded', () => {
    const steps = document.querySelectorAll('.process__step');
    
    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('process__step--visible');
            // optionally stop observing once revealed
            // observer.unobserve(entry.target);
          }
        });
      }, {
        threshold: 0.2, // trigger when 20% visible
        rootMargin: '0px 0px -10% 0px' 
      });

      steps.forEach(step => {
        observer.observe(step);
      });
    } else {
      // Fallback for older browsers
      steps.forEach(step => step.classList.add('process__step--visible'));
    }
  });
</script>

<style>
  .process__header {
    margin-bottom: var(--space-12);
  }

  /* ─── Mobile: vertical flow ─── */
  .process__steps {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
    position: relative;
  }

  .process__step {
    position: relative;
    padding-left: calc(var(--space-12) + var(--space-4));
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .process__step--visible {
    opacity: 1;
    transform: translateY(0);
  }

  .process__step-badge {
    position: absolute;
    left: 0;
    top: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    background-color: var(--color-accent);
    color: var(--color-text-inverse);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    z-index: 1;
  }

  /* Vertical connecting line (mobile) */
  .process__connector {
    position: absolute;
    left: 21px;
    top: 44px;
    width: 2px;
    height: calc(var(--space-10) + 4px);
    background: linear-gradient(to bottom, var(--color-accent), var(--color-border));
  }

  .process__step-title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-2);
  }

  .process__step-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  /* ─── Desktop overrides for vertical layout ─── */
  @media (min-width: 1024px) {
    .process__header {
      text-align: center;
      margin-inline: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .process__steps {
      max-width: 600px;
      margin: 0 auto;
      padding-block: var(--space-10);
    }
    
    /* On desktop, keep the vertical flow but center the line */
    .process__step {
      padding-left: calc(70px + var(--space-6));
    }
    
    .process__step-badge {
      width: 60px;
      height: 60px;
      font-size: var(--text-xl);
    }
    
    .process__connector {
      left: 29px;
      top: 60px;
      height: calc(var(--space-10) + var(--space-4));
    }
    
    .process__step-title {
      font-size: var(--text-2xl);
    }
    
    .process__step-desc {
      font-size: var(--text-base);
    }
  }
</style>
