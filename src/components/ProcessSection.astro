---
import { processSteps, offerName } from '../data/offer';
---

<section class="process section" id="process" aria-labelledby="process-heading" data-process>
  <div class="process__inner container">
    <div class="process__header">
      <span class="eyebrow">Signature engagement</span>
      <h2 class="section-heading" id="process-heading">How the {offerName} works</h2>
      <p class="section-subheading">
        A structured engagement that moves from scattered source systems to one
        trusted operating layer, with progress tied to the scroll instead of
        buried inside a generic step grid.
      </p>
    </div>

    <div class="process__layout">
      <aside class="process__rail-column" aria-hidden="true">
        <div class="process__rail-sticky">
          <div class="process__rail">
            <div class="process__rail-track"></div>
            <div class="process__rail-fill"></div>

            <div class="process__node-list">
              {processSteps.map((item, index) => (
                <div
                  class={`process__node ${index === 0 ? 'process__node--active' : ''}`}
                  data-process-step
                >
                  <span class="process__node-badge">{item.step}</span>
                  <span class="process__node-label">{item.title}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </aside>

      <div class="process__panels">
        {processSteps.map((item, index) => (
          <article
            class={`process__panel ${index === 0 ? 'process__panel--active' : ''}`}
            data-process-panel
          >
            <div class="process__panel-card">
              <span class="process__panel-step">{item.step}</span>
              <h3>{item.title}</h3>
              <p class="process__panel-lead">{item.description}</p>
              <p class="process__panel-detail">{item.detail}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('[data-process]');
    if (!section) return;

    const panels = Array.from(section.querySelectorAll('[data-process-panel]'));
    const nodes = Array.from(section.querySelectorAll('[data-process-step]'));
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const setActive = (activeIndex) => {
      panels.forEach((panel, index) => {
        panel.classList.toggle('process__panel--active', index === activeIndex);
        panel.classList.toggle('process__panel--past', index < activeIndex);
      });

      nodes.forEach((node, index) => {
        node.classList.toggle('process__node--active', index === activeIndex);
        node.classList.toggle('process__node--past', index < activeIndex);
      });
    };

    const updateProgress = () => {
      if (prefersReducedMotion || window.innerWidth < 960) {
        section.style.setProperty('--section-progress', '1');
        return;
      }

      const rect = section.getBoundingClientRect();
      const total = Math.max(section.offsetHeight - window.innerHeight, 1);
      const progress = Math.min(Math.max((-rect.top) / total, 0), 1);
      section.style.setProperty('--section-progress', progress.toFixed(4));
    };

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        const visibleEntries = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);

        if (visibleEntries[0]) {
          const nextIndex = panels.indexOf(visibleEntries[0].target);
          if (nextIndex >= 0) {
            setActive(nextIndex);
          }
        }
      }, {
        threshold: [0.25, 0.5, 0.75],
        rootMargin: '-30% 0px -30% 0px',
      });

      panels.forEach((panel) => observer.observe(panel));
    } else {
      panels.forEach((panel) => panel.classList.add('process__panel--active'));
      nodes.forEach((node) => node.classList.add('process__node--active'));
    }

    updateProgress();
    window.addEventListener('scroll', updateProgress, { passive: true });
    window.addEventListener('resize', updateProgress);
  });
</script>

<style>
  .process {
    --section-progress: 0;
  }

  .process__header {
    max-width: 760px;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }

  .process__header .eyebrow {
    margin-bottom: var(--space-4);
  }

  .process__layout {
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
  }

  .process__rail-column {
    display: none;
  }

  .process__panels {
    display: grid;
    gap: var(--space-6);
  }

  .process__panel {
    opacity: 1;
    transform: none;
  }

  .process__panel-card {
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border-light);
    background: rgba(255, 255, 255, 0.78);
    box-shadow: var(--shadow-sm);
  }

  .process__panel-step {
    display: inline-flex;
    margin-bottom: var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }

  .process__panel-card h3 {
    font-size: clamp(1.75rem, 3vw, 2.6rem);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-4);
  }

  .process__panel-lead {
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    color: var(--color-text);
    margin-bottom: var(--space-4);
    max-width: 30ch;
  }

  .process__panel-detail {
    color: var(--color-text-muted);
    max-width: 40ch;
    line-height: 1.6;
  }

  @media (min-width: 960px) {
    .process__layout {
      grid-template-columns: minmax(17rem, 24rem) minmax(0, 1fr);
      align-items: start;
    }

    .process__rail-column {
      display: block;
      position: relative;
    }

    .process__rail-sticky {
      position: sticky;
      top: 6.5rem;
      height: calc(100vh - 8.5rem);
    }

    .process__rail {
      position: relative;
      height: 100%;
      padding-block: 1rem;
    }

    .process__rail-track,
    .process__rail-fill {
      position: absolute;
      left: 1.55rem;
      top: 1.1rem;
      bottom: 1.1rem;
      width: 2px;
      border-radius: var(--radius-full);
    }

    .process__rail-track {
      background: rgba(29, 29, 31, 0.1);
    }

    .process__rail-fill {
      background: linear-gradient(180deg, rgba(0, 113, 227, 0.3) 0%, rgba(0, 113, 227, 1) 100%);
      transform-origin: top;
      transform: scaleY(var(--section-progress));
      transition: transform 120ms linear;
    }

    .process__node-list {
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: var(--space-6);
    }

    .process__node {
      display: grid;
      grid-template-columns: auto 1fr;
      align-items: center;
      gap: var(--space-4);
      color: var(--color-text-soft);
      transition: color var(--transition-base), transform var(--transition-base);
    }

    .process__node-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 3.1rem;
      height: 3.1rem;
      border-radius: 50%;
      border: 1px solid rgba(29, 29, 31, 0.12);
      background: rgba(255, 255, 255, 0.86);
      font-weight: var(--weight-semibold);
      letter-spacing: -0.02em;
      box-shadow: 0 10px 30px -28px rgba(6, 24, 44, 0.4);
    }

    .process__node-label {
      font-size: var(--text-sm);
      font-weight: var(--weight-semibold);
      max-width: 14ch;
    }

    .process__node--past,
    .process__node--active {
      color: var(--color-text);
    }

    .process__node--active {
      transform: translateX(0.25rem);
    }

    .process__node--past .process__node-badge,
    .process__node--active .process__node-badge {
      border-color: rgba(0, 113, 227, 0.22);
      background: rgba(255, 255, 255, 0.98);
    }

    .process__node--active .process__node-badge {
      color: var(--color-accent);
      box-shadow: 0 20px 45px -30px rgba(0, 113, 227, 0.9);
    }

    .process__panels {
      gap: 0;
    }

    .process__panel {
      min-height: 78vh;
      display: flex;
      align-items: center;
      opacity: 0.26;
      transform: translateX(2rem);
      transition: opacity var(--transition-slow), transform var(--transition-slow);
    }

    .process__panel--past {
      opacity: 0.58;
      transform: translateX(0);
    }

    .process__panel--active {
      opacity: 1;
      transform: translateX(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .process__panel {
      opacity: 1 !important;
      transform: none !important;
    }

    .process__rail-fill {
      transform: scaleY(1) !important;
    }
  }
</style>
