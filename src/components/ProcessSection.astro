---
import { processSteps, offerName } from '../data/offer';
---

<section class="process section" id="process" aria-labelledby="process-heading">
  <div class="process__inner container">
    <div class="process__header">
      <span class="eyebrow">Signature engagement</span>
      <h2 class="section-heading" id="process-heading">How the {offerName} works</h2>
      <p class="section-subheading">
        A structured engagement that moves from scattered source systems to one
        trusted operating layer, with every step visible and easy to follow.
      </p>
    </div>

    <div class="process__list" role="list">
      {processSteps.map((item) => (
        <article class="process__step" role="listitem">
          <div class="process__marker" aria-hidden="true">
            <span class="process__badge">{item.step}</span>
          </div>

          <div class="process__content">
            <span class="process__step-label">{item.step}</span>
            <h3>{item.title}</h3>
            <p class="process__lead">{item.description}</p>
            <p class="process__detail">{item.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .process__header {
    max-width: 760px;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }

  .process__header .eyebrow {
    margin-bottom: var(--space-4);
  }

  .process__list {
    display: grid;
    gap: var(--space-6);
  }

  .process__step {
    display: block;
  }

  .process__marker {
    display: none;
  }

  .process__content {
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border-light);
    background: rgba(255, 255, 255, 0.78);
    box-shadow: var(--shadow-sm);
  }

  .process__step-label {
    display: inline-flex;
    margin-bottom: var(--space-4);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }

  .process__content h3 {
    font-size: clamp(1.75rem, 3vw, 2.6rem);
    letter-spacing: -0.03em;
    margin-bottom: var(--space-4);
  }

  .process__lead {
    font-size: clamp(1.05rem, 1.8vw, 1.25rem);
    color: var(--color-text);
    margin-bottom: var(--space-4);
    max-width: 30ch;
  }

  .process__detail {
    color: var(--color-text-muted);
    max-width: 40ch;
    line-height: 1.6;
  }

  @media (min-width: 960px) {
    .process__list {
      position: relative;
      gap: 0;
      padding-left: 0.5rem;
    }

    .process__list::before {
      content: '';
      position: absolute;
      left: 1.7rem;
      top: 1.9rem;
      bottom: 1.9rem;
      width: 2px;
      border-radius: var(--radius-full);
      background: rgba(29, 29, 31, 0.14);
    }

    .process__step {
      position: relative;
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: clamp(1.5rem, 3vw, 2.25rem);
      align-items: start;
      padding-bottom: clamp(2rem, 4vw, 2.75rem);
    }

    .process__step:last-child {
      padding-bottom: 0;
    }

    .process__marker {
      position: relative;
      display: flex;
      justify-content: center;
      width: 3.5rem;
      z-index: 1;
    }

    .process__badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 3.5rem;
      height: 3.5rem;
      border-radius: 50%;
      border: 1px solid rgba(29, 29, 31, 0.16);
      background: rgba(255, 255, 255, 0.98);
      color: var(--color-text);
      font-size: 1.35rem;
      font-weight: var(--weight-semibold);
      letter-spacing: -0.03em;
      box-shadow: 0 16px 36px -28px rgba(6, 24, 44, 0.32);
    }

    .process__content {
      padding: 0.2rem 0 0;
      border: none;
      background: transparent;
      box-shadow: none;
      border-radius: 0;
      max-width: 54rem;
    }

    .process__step-label {
      display: none;
    }

    .process__content h3 {
      font-size: clamp(2rem, 3.6vw, 2.85rem);
      margin-bottom: var(--space-2);
    }

    .process__lead {
      font-size: clamp(1.15rem, 1.8vw, 1.35rem);
      margin-bottom: var(--space-2);
      max-width: 42rem;
    }

    .process__detail {
      font-size: var(--text-lg);
      max-width: 50rem;
      color: var(--color-text-muted);
    }
  }
</style>
