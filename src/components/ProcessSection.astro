---
import { processSteps, services } from '../data/offer';
---

<section class="services section" id="process" aria-labelledby="services-heading">
  <div class="services__inner container">
    <div class="services__header">
      <h2 class="services__title" id="services-heading">Services</h2>
    </div>

    <div class="services__grid">
      {services.map((service) => (
        <article class="services__card">
          <div class="services__icon" aria-hidden="true">
            {service.icon === 'pipeline' && (
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="10" cy="24" r="5" />
                <circle cx="38" cy="12" r="5" />
                <circle cx="38" cy="36" r="5" />
                <path d="M15 22l18-8M15 26l18 8" />
              </svg>
            )}
            {service.icon === 'automation' && (
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="14" y="14" width="20" height="20" rx="2" />
                <path d="M24 8v6M24 34v6M8 24h6M34 24h6" />
                <circle cx="24" cy="24" r="4" />
              </svg>
            )}
            {service.icon === 'ai' && (
              <svg width="48" height="48" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="24" cy="24" r="14" />
                <path d="M24 16v4M24 28v4M16 24h4M28 24h4" />
                <circle cx="24" cy="24" r="6" />
              </svg>
            )}
          </div>
          <h3 class="services__card-title">{service.title}</h3>
          <p class="services__card-desc">{service.description}</p>
        </article>
      ))}
    </div>

    <div class="services__steps" role="list">
      {processSteps.map((item) => (
        <div class="services__step" role="listitem">
          <span class="services__step-number">{item.step}.</span>
          <span class="services__step-title">{item.title}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services__header {
    text-align: center;
    margin-bottom: clamp(2.5rem, 6vw, 4rem);
  }

  .services__title {
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: var(--weight-bold);
    letter-spacing: -0.04em;
    line-height: 0.9;
    color: var(--color-text);
    text-transform: uppercase;
  }

  .services__grid {
    display: grid;
    gap: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .services__card {
    text-align: center;
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 2vw, 1.5rem);
  }

  .services__icon {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-5);
    color: var(--color-text-soft);
  }

  .services__card-title {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-3);
  }

  .services__card-desc {
    color: var(--color-text-muted);
    max-width: 28ch;
    margin-inline: auto;
    line-height: 1.55;
  }

  .services__steps {
    display: grid;
    gap: clamp(1rem, 2vw, 1.5rem);
    padding-top: clamp(2rem, 4vw, 3rem);
    border-top: 2px solid var(--color-text);
  }

  .services__step {
    padding-top: var(--space-4);
  }

  .services__step-number {
    display: block;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: var(--weight-bold);
    letter-spacing: -0.03em;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .services__step-title {
    display: block;
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  @media (min-width: 640px) {
    .services__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .services__steps {
      grid-template-columns: repeat(5, minmax(0, 1fr));
    }

    .services__step {
      border-top: none;
    }
  }
</style>
