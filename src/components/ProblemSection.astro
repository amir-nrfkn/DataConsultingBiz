---
/**
 * ProblemSection.astro — "Why AI projects fail" section.
 *
 * Displays 6 problem cards in a responsive grid (3×2 on desktop,
 * 2×3 on tablet, single column on mobile). Each card has an icon,
 * title, and short description. Cards use hover elevation.
 */
import { problems } from '../data/offer';
---

<section class="problem section section--alt" id="problem" aria-labelledby="problem-heading">
  <div class="problem__inner container">
    <div class="problem__header">
      <h2 class="section-heading" id="problem-heading">
        Why most internal AI projects fail before they start
      </h2>
      <p class="section-subheading">
        The problem is rarely the AI itself — it's the data underneath.
      </p>
    </div>

    <div class="problem__grid">
      {problems.map((item) => (
        <div class="card problem__card">
          <div class="problem__icon" aria-hidden="true">
            {item.icon === 'scatter' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <circle cx="6" cy="6" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="18" cy="8" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="10" cy="16" r="2.5" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="17" cy="18" r="2.5" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            )}
            {item.icon === 'conflict' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M8 4v16M16 4v16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M4 12h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <path d="M5 8l3 4-3 4M19 8l-3 4 3 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {item.icon === 'slow' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
                <path d="M12 7v5l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {item.icon === 'tools' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
            {item.icon === 'spreadsheet' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <rect x="3" y="3" width="18" height="18" rx="2" stroke="currentColor" stroke-width="1.5"/>
                <path d="M3 9h18M3 15h18M9 3v18M15 3v18" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            )}
            {item.icon === 'ai' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                <path d="M12 2L2 7l10 5 10-5-10-5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M2 17l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </div>
          <h3 class="problem__title">{item.title}</h3>
          <p class="problem__description">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .problem__header {
    margin-bottom: var(--space-12);
  }

  .problem__grid {
    display: grid;
    gap: var(--space-6);
  }

  .problem__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .problem__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--color-accent-light);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .problem__title {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
  }

  .problem__description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  @media (min-width: 640px) {
    .problem__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .problem__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
