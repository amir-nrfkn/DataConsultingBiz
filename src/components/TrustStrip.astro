---
/**
 * TrustStrip.astro — Horizontal trust/context strip below the hero.
 *
 * Displays 4 trust items with inline SVG icons separated by subtle
 * dividers. Wraps to a 2×2 grid on mobile. No fake client logos —
 * uses factual capability statements instead.
 */
import { trustItems } from '../data/offer';
---

<section class="trust-strip" aria-label="Key capabilities">
  <div class="trust-strip__inner container">
    {trustItems.map((item, i) => (
      <div class="trust-strip__item">
        <span class="trust-strip__icon" aria-hidden="true">
          {item.icon === 'team' && (
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <circle cx="7" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="13" cy="7" r="3" stroke="currentColor" stroke-width="1.5"/>
              <path d="M2 17c0-2.8 2.2-5 5-5s5 2.2 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <path d="M13 12c2.8 0 5 2.2 5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          )}
          {item.icon === 'ai' && (
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <rect x="3" y="3" width="14" height="14" rx="3" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="7.5" cy="8.5" r="1" fill="currentColor"/>
              <circle cx="12.5" cy="8.5" r="1" fill="currentColor"/>
              <path d="M7.5 13c1 1.2 3.5 1.2 5 0" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          )}
          {item.icon === 'cloud' && (
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M5.5 15A3.5 3.5 0 015 8.2 5 5 0 0114.9 9a3 3 0 01-.9 5.9H5.5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          )}
          {item.icon === 'messaging' && (
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 5h12a1 1 0 011 1v7a1 1 0 01-1 1h-3l-3 3-3-3H4a1 1 0 01-1-1V6a1 1 0 011-1z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          )}
        </span>
        <span class="trust-strip__label">{item.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .trust-strip {
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    background-color: var(--color-surface);
    padding-block: var(--space-6);
  }

  .trust-strip__inner {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-6);
  }

  .trust-strip__item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .trust-strip__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    background: var(--color-accent-light);
    color: var(--color-accent);
  }

  .trust-strip__label {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    line-height: var(--leading-tight);
  }

  @media (min-width: 768px) {
    .trust-strip__inner {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-8);
    }

    .trust-strip {
      padding-block: var(--space-8);
    }
  }
</style>
