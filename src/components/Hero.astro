---
/**
 * Hero.astro — The most important section of the homepage.
 *
 * Two-column layout (desktop): text + CTAs on the left, a composed
 * HTML/CSS visual on the right showing:
 *   1. A "Trusted Data Layer" diagram with connected system nodes
 *   2. A mini AI chat bubble mockup
 *   3. A data quality status badge
 *
 * All visuals are pure HTML/CSS — zero images, fully responsive.
 */
import { hero } from '../data/offer';
---

<section class="hero section" id="hero" aria-labelledby="hero-heading">
  <div class="hero__inner container">
    <!-- Left column: headline, subheadline, CTAs -->
    <div class="hero__content">
      <h1 class="hero__headline" id="hero-heading">
        {hero.headline}
      </h1>
      <p class="hero__subheadline">
        {hero.subheadline}
      </p>
      <div class="hero__ctas">
        <a href="#contact" class="btn btn-primary hero__cta-primary">
          {hero.ctaPrimary}
        </a>
        <a href="#process" class="btn btn-secondary hero__cta-secondary">
          {hero.ctaSecondary}
        </a>
      </div>
    </div>

    <!-- Right column: composed HTML/CSS visual -->
    <div class="hero__visual" aria-hidden="true">
      <!-- Data layer diagram card -->
      <div class="hero__diagram">
        <div class="hero__diagram-label">Trusted Data Layer</div>
        <div class="hero__diagram-sources">
          <div class="hero__source-node">
            <span class="hero__source-icon">⊞</span>
            <span class="hero__source-name">ERP</span>
          </div>
          <div class="hero__source-node">
            <span class="hero__source-icon">⊕</span>
            <span class="hero__source-name">CRM</span>
          </div>
          <div class="hero__source-node">
            <span class="hero__source-icon">⊡</span>
            <span class="hero__source-name">HR</span>
          </div>
          <div class="hero__source-node">
            <span class="hero__source-icon">⊠</span>
            <span class="hero__source-name">Finance</span>
          </div>
        </div>
        <div class="hero__diagram-flow">
          <div class="hero__flow-line"></div>
          <div class="hero__flow-center">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.5"/>
              <path d="M5 9h8M9 5v8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="hero__flow-line"></div>
        </div>
        <div class="hero__diagram-output">
          <span class="hero__output-badge">✓ Validated</span>
          <span class="hero__output-badge">✓ Centralized</span>
          <span class="hero__output-badge">✓ Trusted</span>
        </div>
      </div>

      <!-- AI chat mockup -->
      <div class="hero__chat">
        <div class="hero__chat-header">
          <span class="hero__chat-dot"></span>
          <span class="hero__chat-title">AI Analyst</span>
        </div>
        <div class="hero__chat-body">
          <div class="hero__chat-bubble hero__chat-bubble--user">
            What was our scrap rate last week?
          </div>
          <div class="hero__chat-bubble hero__chat-bubble--ai">
            Scrap rate for Week 14 was 3.2%, down from 4.1% the prior week. Top contributor: Line B material waste.
          </div>
        </div>
      </div>

      <!-- Data quality badge -->
      <div class="hero__quality-badge">
        <div class="hero__quality-icon">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="7" stroke="#0D8A93" stroke-width="1.5"/>
            <path d="M5 8.5l2 2 4-4" stroke="#0D8A93" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="hero__quality-text">
          <span class="hero__quality-label">Pipeline Status</span>
          <span class="hero__quality-value">12/12 checks passed</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
    overflow: hidden;
  }

  .hero__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    align-items: center;
    text-align: center;
  }

  /* ─── Content column ─── */

  .hero__headline {
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    max-width: 24ch;
    margin-bottom: var(--space-6);
    margin-inline: auto;
  }

  .hero__subheadline {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    max-width: 48ch;
    margin-bottom: var(--space-8);
    margin-inline: auto;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
  }

  /* ─── Visual column ─── */

  .hero__visual {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* --- Diagram card --- */
  .hero__diagram {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    box-shadow: var(--shadow-md);
  }

  .hero__diagram-label {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .hero__diagram-sources {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .hero__source-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2);
    background: var(--color-surface-alt);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border-light);
  }

  .hero__source-icon {
    font-size: var(--text-lg);
    color: var(--color-accent);
  }

  .hero__source-name {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
  }

  .hero__diagram-flow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-2) 0;
  }

  .hero__flow-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, var(--color-accent) 50%, transparent 100%);
  }

  .hero__flow-center {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    background: var(--color-accent-light);
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .hero__diagram-output {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .hero__output-badge {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    color: var(--color-accent-dark);
    background: var(--color-accent-light);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
  }

  /* --- Chat mockup --- */
  .hero__chat {
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .hero__chat-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface-alt);
    border-bottom: 1px solid var(--color-border-light);
  }

  .hero__chat-dot {
    width: 8px;
    height: 8px;
    border-radius: var(--radius-full);
    background: #34c759;
  }

  .hero__chat-title {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .hero__chat-body {
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero__chat-bubble {
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-lg);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    max-width: 85%;
  }

  .hero__chat-bubble--user {
    background: var(--color-accent);
    color: var(--color-text-inverse);
    align-self: flex-end;
    border-bottom-right-radius: var(--radius-sm);
  }

  .hero__chat-bubble--ai {
    background: var(--color-surface-alt);
    color: var(--color-text);
    align-self: flex-start;
    border-bottom-left-radius: var(--radius-sm);
  }

  /* --- Quality badge --- */
  .hero__quality-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-5);
    box-shadow: var(--shadow-sm);
    align-self: flex-start;
  }

  .hero__quality-icon {
    flex-shrink: 0;
  }

  .hero__quality-text {
    display: flex;
    flex-direction: column;
  }

  .hero__quality-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-weight: var(--weight-medium);
  }

  .hero__quality-value {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-accent-dark);
  }

  /* ─── Responsive ─── */

  @media (min-width: 768px) {
    .hero__headline {
      font-size: var(--text-4xl);
    }
  }

  @media (min-width: 1024px) {
    .hero__inner {
      gap: var(--space-16);
    }

    .hero__headline {
      font-size: var(--text-5xl);
    }
  }
</style>
