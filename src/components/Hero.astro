---
import { hero } from '../data/offer';
import { site } from '../data/site';
import DataFlowDiagram from './DataFlowDiagram.astro';

const isExternalBooking = site.bookingUrl.startsWith('http');
---

<section class="hero section" id="hero" aria-labelledby="hero-heading">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="hero__inner container">
    <div class="hero__content">
      <span class="eyebrow hero__eyebrow">{hero.eyebrow}</span>
      <h1 class="hero__headline" id="hero-heading">{hero.headline}</h1>
      <p class="hero__subheadline">{hero.subheadline}</p>

      <div class="hero__ctas">
        <a
          href={site.bookingUrl}
          class="btn btn-primary"
          target={isExternalBooking ? '_blank' : undefined}
          rel={isExternalBooking ? 'noreferrer' : undefined}
        >
          {site.bookingLabel}
        </a>
        <p class="hero__cta-alt">
          Not ready? <a href="#contact">Send your details instead</a>
        </p>
      </div>


      <ul class="hero__highlights" role="list">
        {hero.highlights.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>

    <div class="hero__diagram">
      <DataFlowDiagram />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(5.25rem, 10vw, 8rem);
    padding-bottom: clamp(4rem, 8vw, 6.5rem);
  }

  .hero__glow {
    position: absolute;
    inset: -10% auto auto 50%;
    width: min(42rem, 80vw);
    height: min(42rem, 80vw);
    transform: translateX(-50%);
    background: radial-gradient(circle, rgba(0, 113, 227, 0.16) 0%, rgba(0, 113, 227, 0.03) 36%, transparent 68%);
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(2.5rem, 6vw, 4rem);
  }

  .hero__content {
    max-width: 44rem;
    text-align: center;
  }

  .hero__eyebrow {
    margin-bottom: var(--space-5);
  }

  .hero__headline {
    font-size: clamp(3rem, 7vw, var(--text-6xl));
    line-height: 0.95;
    letter-spacing: -0.055em;
    margin-inline: auto;
    margin-bottom: var(--space-6);
  }

  .hero__subheadline {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.58;
    color: var(--color-text-muted);
    max-width: 34rem;
    margin-inline: auto;
    margin-bottom: var(--space-8);
  }

  .hero__ctas {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
  }

  .hero__cta-alt {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .hero__cta-alt a {
    color: var(--color-text);
    text-decoration: underline;
  }

  .hero__trust-proof {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-soft);
    margin-bottom: var(--space-6);
  }

  .hero__highlights {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3) var(--space-5);
    color: var(--color-text-soft);
    font-size: var(--text-sm);
  }

  .hero__highlights li {
    position: relative;
    padding-left: 1rem;
  }

  .hero__highlights li::before {
    content: '';
    position: absolute;
    top: 0.45rem;
    left: 0;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .hero__diagram {
    width: 100%;
    max-width: 52rem;
    margin-inline: auto;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__content {
      animation: hero-rise 900ms var(--transition-slow) both;
    }

    .hero__diagram {
      animation: hero-rise 900ms var(--transition-slow) both;
      animation-delay: 120ms;
    }
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(22px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
