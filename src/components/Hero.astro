---
import { hero } from '../data/offer';
import { site } from '../data/site';

const isExternalBooking = site.bookingUrl.startsWith('http');
---

<section class="hero section" id="hero" aria-labelledby="hero-heading">
  <div class="hero__glow" aria-hidden="true"></div>
  <div class="hero__inner container">
    <div class="hero__content">
      <span class="eyebrow hero__eyebrow">{hero.eyebrow}</span>
      <h1 class="hero__headline" id="hero-heading">{hero.headline}</h1>
      <p class="hero__subheadline">{hero.subheadline}</p>

      <div class="hero__ctas">
        <a
          href={site.bookingUrl}
          class="btn btn-primary"
          target={isExternalBooking ? '_blank' : undefined}
          rel={isExternalBooking ? 'noreferrer' : undefined}
        >
          {site.bookingLabel}
        </a>
        <a href="#contact" class="btn btn-secondary">{hero.ctaSecondary}</a>
      </div>

      <ul class="hero__highlights" role="list">
        {hero.highlights.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>

    <div class="hero__visual card" aria-hidden="true">
      <div class="hero__visual-header">
        <span>{hero.visualTitle}</span>
        <span class="hero__status">Validated</span>
      </div>

      <div class="hero__source-row">
        {hero.visualSources.map((source) => (
          <span class="hero__source-pill">{source}</span>
        ))}
      </div>

      <div class="hero__screen">
        <div class="hero__screen-line"></div>
        <div class="hero__screen-body">
          <div class="hero__prompt">{hero.visualPrompt}</div>
          <div class="hero__response">
            <span class="hero__response-label">AI analyst</span>
            <p>{hero.visualResponse}</p>
          </div>
        </div>
      </div>

      <div class="hero__stats">
        {hero.visualStats.map((item) => (
          <div class="hero__stat">
            <span class="hero__stat-value">{item.value}</span>
            <span class="hero__stat-label">{item.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: clamp(5.25rem, 10vw, 8rem);
    padding-bottom: clamp(4rem, 8vw, 6.5rem);
  }

  .hero__glow {
    position: absolute;
    inset: -10% auto auto 50%;
    width: min(42rem, 80vw);
    height: min(42rem, 80vw);
    transform: translateX(-10%);
    background: radial-gradient(circle, rgba(0, 113, 227, 0.16) 0%, rgba(0, 113, 227, 0.03) 36%, transparent 68%);
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    display: grid;
    gap: clamp(2.25rem, 6vw, 4.5rem);
    align-items: center;
  }

  .hero__content {
    max-width: 44rem;
  }

  .hero__eyebrow {
    margin-bottom: var(--space-5);
  }

  .hero__headline {
    font-size: clamp(3rem, 7vw, var(--text-6xl));
    line-height: 0.95;
    letter-spacing: -0.055em;
    max-width: 11.5ch;
    margin-bottom: var(--space-6);
  }

  .hero__subheadline {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    line-height: 1.58;
    color: var(--color-text-muted);
    max-width: 34rem;
    margin-bottom: var(--space-8);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .hero__highlights {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-5);
    color: var(--color-text-soft);
    font-size: var(--text-sm);
  }

  .hero__highlights li {
    position: relative;
    padding-left: 1rem;
  }

  .hero__highlights li::before {
    content: '';
    position: absolute;
    top: 0.45rem;
    left: 0;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 50%;
    background: var(--color-accent);
  }

  .hero__visual {
    position: relative;
    padding: clamp(1.2rem, 3vw, 1.6rem);
    overflow: hidden;
  }

  .hero__visual::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.92) 0%, rgba(232, 243, 255, 0.82) 100%);
    pointer-events: none;
  }

  .hero__visual > * {
    position: relative;
  }

  .hero__visual-header,
  .hero__source-row,
  .hero__stats {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-3);
  }

  .hero__visual-header {
    margin-bottom: var(--space-5);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-soft);
  }

  .hero__status {
    padding: 0.45rem 0.7rem;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.72);
    color: var(--color-accent);
  }

  .hero__source-row {
    justify-content: flex-start;
    flex-wrap: wrap;
    margin-bottom: var(--space-5);
  }

  .hero__source-pill {
    padding: 0.55rem 0.82rem;
    border-radius: var(--radius-full);
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(29, 29, 31, 0.08);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .hero__screen {
    position: relative;
    padding: var(--space-6);
    border-radius: calc(var(--radius-xl) - 10px);
    background: linear-gradient(180deg, rgba(250, 251, 255, 0.96) 0%, rgba(242, 245, 250, 0.88) 100%);
    border: 1px solid rgba(29, 29, 31, 0.06);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
  }

  .hero__screen-line {
    position: absolute;
    left: 1.3rem;
    top: 1.25rem;
    bottom: 1.25rem;
    width: 2px;
    border-radius: var(--radius-full);
    background: linear-gradient(180deg, rgba(0, 113, 227, 0.12) 0%, rgba(0, 113, 227, 0.75) 55%, rgba(0, 113, 227, 0.16) 100%);
  }

  .hero__screen-body {
    padding-left: 1.6rem;
    display: grid;
    gap: var(--space-4);
  }

  .hero__prompt {
    display: inline-flex;
    width: fit-content;
    max-width: 22rem;
    padding: 0.85rem 1rem;
    border-radius: 1.15rem 1.15rem 1.15rem 0.45rem;
    background: rgba(255, 255, 255, 0.95);
    color: var(--color-text);
    font-weight: var(--weight-medium);
    box-shadow: 0 12px 28px -24px rgba(6, 24, 44, 0.35);
  }

  .hero__response {
    padding: 1rem 1.05rem;
    border-radius: 1.2rem 1.2rem 0.55rem 1.2rem;
    background: linear-gradient(180deg, rgba(0, 113, 227, 0.1) 0%, rgba(0, 113, 227, 0.16) 100%);
    border: 1px solid rgba(0, 113, 227, 0.14);
  }

  .hero__response-label {
    display: inline-block;
    margin-bottom: var(--space-2);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
  }

  .hero__response p {
    color: var(--color-text);
    max-width: 34ch;
  }

  .hero__stats {
    margin-top: var(--space-5);
    flex-direction: column;
    align-items: stretch;
  }

  .hero__stat {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(29, 29, 31, 0.08);
  }

  .hero__stat-value {
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
    letter-spacing: -0.02em;
  }

  .hero__stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    text-align: right;
  }

  @media (min-width: 980px) {
    .hero__inner {
      grid-template-columns: minmax(0, 1fr) minmax(28rem, 36rem);
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero__content,
    .hero__visual {
      animation: hero-rise 900ms var(--transition-slow) both;
    }

    .hero__visual {
      animation-delay: 120ms;
    }
  }

  @keyframes hero-rise {
    from {
      opacity: 0;
      transform: translateY(22px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
