---
/**
 * BaseLayout.astro — Root layout wrapping every page.
 *
 * Provides the HTML shell, imports global CSS, renders the SeoHead,
 * Header, Footer, and a skip-to-content link for accessibility.
 * Individual pages pass SEO props and optional JSON-LD schemas.
 */
import SeoHead from '../components/SeoHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { SeoProps } from '../utils/seo';
import '../styles/global.css';

interface Props {
  seo: SeoProps;
  schemas?: Record<string, unknown>[];
}

const { seo, schemas = [] } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <SeoHead seo={seo} schemas={schemas} />
  <body>
    <!-- Skip link for keyboard / screen-reader users -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>

<style>
  /* Skip-to-content link — invisible until focused via keyboard. */
  .skip-link {
    position: absolute;
    top: -100%;
    left: var(--space-4);
    z-index: 1000;
    padding: var(--space-2) var(--space-4);
    background-color: var(--color-accent);
    color: var(--color-text-inverse);
    border-radius: var(--radius-md);
    font-weight: var(--weight-semibold);
    font-size: var(--text-sm);
    transition: top var(--transition-fast);
  }

  .skip-link:focus {
    top: var(--space-4);
  }
</style>
