---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CapabilitySection from '../components/CapabilitySection.astro';
import ProcessSection from '../components/ProcessSection.astro';
import ExamplesSection from '../components/ExamplesSection.astro';
import DeliverablesSection from '../components/DeliverablesSection.astro';
import IdealClientSection from '../components/IdealClientSection.astro';
import FAQSection from '../components/FAQSection.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import { site } from '../data/site';
import {
  getOrganizationSchema,
  getServiceSchema,
  getFaqSchema,
} from '../utils/schema';

const seo = {
  title: site.defaultTitle,
  description: site.defaultDescription,
  canonicalPath: '/',
};

const schemas = [
  getOrganizationSchema(),
  getServiceSchema(),
  getFaqSchema(),
];
---

<BaseLayout seo={seo} schemas={schemas}>
  <Hero />
  <CapabilitySection />
  <ProcessSection />
  <ExamplesSection />
  <DeliverablesSection />
  <IdealClientSection />
  <FAQSection />
  <ContactFormSection />
</BaseLayout>
