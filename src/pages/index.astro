---
/**
 * index.astro — Homepage for Veylor Advisory.
 *
 * Assembles all 12 homepage sections in the correct order inside
 * BaseLayout. Passes SEO props and JSON-LD structured data schemas
 * (Organization, Service, FAQPage) for search engine / AI visibility.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import ProblemSection from '../components/ProblemSection.astro';
import ProcessSection from '../components/ProcessSection.astro';
import DeliverablesSection from '../components/DeliverablesSection.astro';
import ExamplesSection from '../components/ExamplesSection.astro';
import TechnologySection from '../components/TechnologySection.astro';
import IdealClientSection from '../components/IdealClientSection.astro';
import FAQSection from '../components/FAQSection.astro';
import ContactFormSection from '../components/ContactFormSection.astro';
import { site } from '../data/site';
import {
  getOrganizationSchema,
  getServiceSchema,
  getFaqSchema,
} from '../utils/schema';

const seo = {
  title: site.defaultTitle,
  description: site.defaultDescription,
  canonicalPath: '/',
};

const schemas = [
  getOrganizationSchema(),
  getServiceSchema(),
  getFaqSchema(),
];
---

<BaseLayout seo={seo} schemas={schemas}>
  <Hero />
  <TrustStrip />
  <ProblemSection />
  <ProcessSection />
  <DeliverablesSection />
  <ExamplesSection />
  <TechnologySection />
  <IdealClientSection />
  <FAQSection />
  <ContactFormSection />
</BaseLayout>
