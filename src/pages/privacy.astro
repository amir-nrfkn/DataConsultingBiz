---
/**
 * privacy.astro — Privacy policy page.
 *
 * Covers what information is collected via the lead capture form,
 * how it's used, and how to contact for privacy concerns.
 * Uses placeholder business/contact info.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';

const seo = {
  title: `Privacy Policy | ${site.name}`,
  description: `Privacy policy for ${site.name}. Learn about the information we collect and how we use it.`,
  canonicalPath: '/privacy',
};
---

<BaseLayout seo={seo}>
  <section class="privacy section" aria-labelledby="privacy-heading">
    <div class="privacy__inner container">
      <h1 class="privacy__heading" id="privacy-heading">Privacy Policy</h1>
      <p class="privacy__updated">Last updated: April 2026</p>

      <div class="privacy__content">
        <h2>Information We Collect</h2>
        <p>
          When you submit our inquiry form, we collect the following information:
        </p>
        <ul>
          <li>Your name and work email address</li>
          <li>Company name, size, and industry</li>
          <li>Current systems used and the data/reporting issues you describe</li>
          <li>Phone number (if you choose to provide it)</li>
          <li>Any additional message you include</li>
        </ul>

        <h2>How We Use Your Information</h2>
        <p>
          We use the information you provide solely to:
        </p>
        <ul>
          <li>Understand your business context and data challenges</li>
          <li>Respond to your inquiry with relevant information</li>
          <li>Determine whether our engagement is a good fit for your needs</li>
        </ul>
        <p>
          We do not sell, rent, or share your personal information with third
          parties for marketing purposes. We do not send automated sales
          sequences or add you to marketing email lists.
        </p>

        <h2>Form Hosting</h2>
        <p>
          Our inquiry form is processed by Netlify, our hosting provider. Form
          submissions are stored securely in Netlify's infrastructure and are
          accessible only to authorized members of our team. For more
          information, see
          <a href="https://www.netlify.com/privacy/" target="_blank" rel="noopener noreferrer">
            Netlify's privacy policy</a>.
        </p>

        <h2>Cookies & Tracking</h2>
        <p>
          This website does not use cookies, analytics trackers, or third-party
          scripts that collect personal information.
        </p>

        <h2>Your Rights</h2>
        <p>
          You may request access to, correction of, or deletion of your
          personal information at any time by contacting us.
        </p>

        <h2>Contact</h2>
        <p>
          For privacy-related questions or requests, contact us at
          <a href={`mailto:${site.email}`}>{site.email}</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .privacy__inner {
    max-width: 720px;
  }

  .privacy__heading {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-2);
  }

  .privacy__updated {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-12);
  }

  .privacy__content h2 {
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }

  .privacy__content p {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .privacy__content ul {
    list-style: disc;
    padding-left: var(--space-6);
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .privacy__content li {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  .privacy__content a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .privacy__content a:hover {
    color: var(--color-accent-dark);
  }
</style>
